{
  "mcpServers": {
    "tipi-consciousness": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh",
      "args": ["tipi.mcp.consciousness.server"]
    },
    "tipi-dizzy": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh",
      "args": ["tipi.mcp.dizzy.server"]
    },
    "tipi-hermes": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh",
      "args": ["tipi.mcp.hermes.server"]
    },
    "tipi-openclaw": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh",
      "args": ["tipi.mcp.openclaw.server"]
    },
    "tipi-claude-spawn": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh",
      "args": ["tipi.mcp.claude_spawn.server"]
    },
    "nate-promptkit": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "${NATE_PROMPTKIT_URL}"
      ],
      "description": "Nate B. Jones Exec Circle library (posts, prompt kits, guides). Requires NATE_PROMPTKIT_URL env var — set it to your subscriber MCP URL."
    }
  }
}
